# ─── Ganesh Provisions Backend Configuration ───
# Fill in your Meta / WhatsApp Business Cloud API credentials below.
# Get these from: https://developers.facebook.com → WhatsApp → API Setup

# Your WhatsApp Business API permanent access token
WHATSAPP_API_TOKEN=your_whatsapp_cloud_api_token_here

# Your WhatsApp Phone Number ID (from Meta Business dashboard)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Port for the backend server (default 3001)
PORT=3001

# ─── Store Owner Dashboard Credentials ───
# Custom username and password to secure the Owner Dashboard portal
OWNER_USERNAME=owner
OWNER_PASSWORD=owner123
